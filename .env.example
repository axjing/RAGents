# Ragent Environment Configuration
# Copy this file to .env and fill in your values

# Database
RAGENT_DB_HOST=localhost
RAGENT_DB_PORT=5432
RAGENT_DB_USER=ragent
RAGENT_DB_PASSWORD=ragent
RAGENT_DB_NAME=ragent

# Vector Database (Milvus)
RAGENT_VECTOR_MILVUS_ENABLED=false
RAGENT_VECTOR_MILVUS_HOST=localhost
RAGENT_VECTOR_MILVUS_PORT=19530
RAGENT_VECTOR_MILVUS_USER=
RAGENT_VECTOR_MILVUS_PASSWORD=
RAGENT_VECTOR_MILVUS_SECURE=false

# Object Storage (MinIO)
RAGENT_STORAGE_ENDPOINT=localhost:9000
RAGENT_STORAGE_ACCESS_KEY=minioadmin
RAGENT_STORAGE_SECRET_KEY=minioadmin
RAGENT_STORAGE_BUCKET=ragent
RAGENT_STORAGE_SECURE=false
RAGENT_STORAGE_REGION=us-east-1

# LLM Provider
RAGENT_LLM_PROVIDER=mock
RAGENT_LLM_MODEL=mock-gpt-4
RAGENT_LLM_API_KEY=
RAGENT_LLM_BASE_URL=
RAGENT_LLM_TEMPERATURE=0.7
RAGENT_LLM_MAX_TOKENS=
RAGENT_LLM_TIMEOUT=30.0
RAGENT_LLM_MAX_RETRIES=3

# Embedding Provider
RAGENT_EMBEDDING_PROVIDER=mock
RAGENT_EMBEDDING_MODEL=mock-embedding
RAGENT_EMBEDDING_API_KEY=
RAGENT_EMBEDDING_BASE_URL=
RAGENT_EMBEDDING_DIMENSION=768
RAGENT_EMBEDDING_TIMEOUT=30.0
RAGENT_EMBEDDING_MAX_RETRIES=3

# Retrieval
RAGENT_RETRIEVAL_TOP_K=10
RAGENT_RETRIEVAL_BM25_WEIGHT=0.3
RAGENT_RETRIEVAL_VECTOR_WEIGHT=0.7
RAGENT_RETRIEVAL_RERANK_ENABLED=false
RAGENT_RETRIEVAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAGENT_RETRIEVAL_RERANK_TOP_K=5

# Ingestion
RAGENT_INGEST_CHUNK_SIZE=1000
RAGENT_INGEST_CHUNK_OVERLAP=200
RAGENT_INGEST_MAX_FILE_SIZE_MB=100

# API
RAGENT_API_HOST=0.0.0.0
RAGENT_API_PORT=8000
RAGENT_API_WORKERS=1
RAGENT_API_CORS_ORIGINS=*
RAGENT_API_RATE_LIMIT=100

# Logging
RAGENT_LOG_LEVEL=INFO
RAGENT_LOG_FORMAT=console
RAGENT_LOG_FILE=

# Application
RAGENT_ENVIRONMENT=development
RAGENT_DEBUG=true